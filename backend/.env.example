# ============================================================
# SandStorm Kenya — Backend Production Environment Variables
# ============================================================
# Copy these into Railway → Service → Variables
# DO NOT commit this file with real values filled in.

# ── Database ─────────────────────────────────────────────────
# Use Railway's variable reference — auto-filled when you add the PostgreSQL plugin:
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── Secrets (generate strong random values — never use the local placeholders) ──
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
COOKIE_SECRET=REPLACE_WITH_STRONG_SECRET

# ── CORS ─────────────────────────────────────────────────────
# Replace YOUR-SITE.vercel.app with your actual Vercel URL after deployment
STORE_CORS=https://YOUR-SITE.vercel.app,https://sandstormkenya.com
ADMIN_CORS=https://YOUR-BACKEND.up.railway.app
AUTH_CORS=https://YOUR-SITE.vercel.app,https://sandstormkenya.com,https://YOUR-BACKEND.up.railway.app

# ── Medusa ───────────────────────────────────────────────────
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# ── Optional ─────────────────────────────────────────────────
# RESEND_API_KEY=re_...   # Order confirmation emails (optional)
